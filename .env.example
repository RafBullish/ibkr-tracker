# ============================================================
# QuantumCall — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git (already in .gitignore).
# ⚠ SERVER-SIDE ONLY — never prefix these with VITE_ or they
#   leak into the frontend bundle.
# ============================================================

# Finnhub API key — REQUIRED for stock quotes, earnings,
# economic data. Get a free key at https://finnhub.io/
# Consumed by: api/finnhub/[ticker].js, api/finnhub/earnings.js,
# api/finnhub/economic.js, api/health/finnhub.js,
# api/quote/[ticker].js
FINNHUB_KEY=

# Twelve Data API key — OPTIONAL fallback for USD/CHF FX rates.
# If omitted, falls back to Frankfurter (ECB, free, no key needed).
# Consumed by: api/fx/usdchf.js
TWELVE_DATA_KEY=

# CORS allowed origins — REQUIRED in production. Comma-separated
# list of allowed frontend origins. In production, the API rejects
# any cross-origin request whose Origin header is not in this list
# (or the auto-set VERCEL_URL). No permissive fallback.
# In development, only http://localhost:5173 and http://localhost:3000
# are accepted regardless of this setting.
# Consumed by: api/_cors.js
ALLOWED_ORIGINS=https://ibkr-tracker-delta.vercel.app

# Feature flags (UI gates).
# ⚠ VITE_-prefixed = exposed in the browser bundle. OK for ON/OFF UI
# toggles, NEVER for secrets. Compared as the literal string 'true'.
VITE_FEATURE_GREEK_CENTER=true
